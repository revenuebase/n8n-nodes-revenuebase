{
	"name": "@revenuebase/n8n-nodes-revenuebase",
	"version": "0.2.3",
	"description": "n8n community node for the RevenueBase B2B data and email verification API",
	"license": "MIT",
	"homepage": "https://docs.revenuebase.ai",
	"keywords": [
		"n8n-community-node-package",
		"revenuebase",
		"b2b",
		"email-verification",
		"company-enrichment"
	],
	"author": {
		"name": "RevenueBase",
		"email": "community@revenuebase.ai"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/revenuebase/n8n-nodes-revenuebase.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/RevenueBaseApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/RevenueBase/RevenueBase.node.js"
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@n8n/node-cli": "*",
		"@types/node": "^25.6.0",
		"eslint": "9.39.4",
		"n8n-workflow": "^2.13.1",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
